@model IEnumerable<AlphaFleet.Data.Models.Battle>
@using AlphaFleet.Data.Models.Enums

@{
    ViewData["Title"] = "Battles";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">⚔️ @ViewData["Title"]</h1>
        <a asp-controller="Battle" asp-action="InitiateBattle" class="btn btn-danger">⚔️ Initiate Battle</a>
    </div>

    <form asp-controller="Battle" asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control"
                   placeholder="Search by fleet or station name..."
                   value="@ViewData["CurrentSearch"]" />
            <button type="submit" class="btn btn-primary">🔍 Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <a asp-controller="Battle" asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
            }
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info" role="alert">
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <span>No battles found matching "<strong>@ViewData["CurrentSearch"]</strong>".</span>
            }
            else
            {
                <span>No battles recorded yet. <a asp-controller="Battle" asp-action="InitiateBattle">Initiate the first battle!</a></span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Attacking Fleet</th>
                        <th>Defenders</th>
                        <th>Outcome</th>
                        <th>Turns</th>
                        <th>Total Damage</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var battle in Model)
                    {
                        <tr>
                            <td><strong>@battle.AttackingFleet?.Name</strong></td>
                            <td>
                                @if (battle.DefendingFleet != null)
                                {
                                    <span>@battle.DefendingFleet.Name</span>
                                    <span class="text-muted"> + </span>
                                }
                                <span>@battle.DefendingStation?.Name</span>
                            </td>
                            <td>
                                <span class="badge bg-@GetOutcomeBadge(battle.Outcome)">
                                    @battle.Outcome
                                </span>
                            </td>
                            <td>@battle.TurnsPlayed</td>
                            <td>@battle.DamageDealt.ToString("N0")</td>
                            <td>@battle.StartTime.ToString("yyyy-MM-dd")</td>
                            <td>
                                <a asp-controller="Battle" asp-action="Details" asp-route-id="@battle.Id"
                                   class="btn btn-sm btn-outline-info">📋 View Log</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    private string GetOutcomeBadge(BattleOutcome outcome) => outcome switch
    {
        BattleOutcome.Victory => "success",
        BattleOutcome.Defeat  => "danger",
        BattleOutcome.Draw    => "warning",
        _                     => "info"
    };
}
