@model IEnumerable<AlphaFleet.Data.Models.Battle>

@{
    ViewData["Title"] = "Battles";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <!-- TODO: Add Initiate Battle action link when implemented -->
    </div>

    <form asp-controller="Battle" asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by attacking fleet or defending station..."
                   value="@ViewData["CurrentSearch"]" />
            <button type="submit" class="btn btn-primary">🔍 Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <a asp-controller="Battle" asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
            }
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info" role="alert">
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <span>No battles found matching "<strong>@ViewData["CurrentSearch"]</strong>".</span>
            }
            else
            {
                <span>No battles found.</span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Start Time</th>
                        <th>Attacking Fleet</th>
                        <th>Defending Station</th>
                        <th>Outcome</th>
                        <th>Damage Dealt</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var battle in Model)
                    {
                        <tr>
                            <td>@battle.StartTime.ToString("g")</td>
                            <td>
                                <a asp-controller="Fleet" asp-action="Details" asp-route-id="@battle.AttackingFleetId">
                                    @battle.AttackingFleet.Name
                                </a>
                            </td>
                            <td>
                                <a asp-controller="Station" asp-action="Details" asp-route-id="@battle.DefendingStationId">
                                    @battle.DefendingStation.Name
                                </a>
                            </td>
                            <td>
                                <span class="badge bg-@GetOutcomeColor(battle.Outcome)">@battle.Outcome</span>
                            </td>
                            <td>@battle.DamageDealt</td>
                            <td>
                                <a asp-controller="Battle" asp-action="Details" asp-route-id="@battle.Id" class="btn btn-sm btn-outline-primary">📋 Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>

@functions {
    private string GetOutcomeColor(AlphaFleet.Data.Models.Enums.BattleOutcome outcome)
    {
        return outcome switch
        {
            AlphaFleet.Data.Models.Enums.BattleOutcome.Victory => "success",
            AlphaFleet.Data.Models.Enums.BattleOutcome.Defeat => "danger",
            AlphaFleet.Data.Models.Enums.BattleOutcome.Draw => "warning",
            AlphaFleet.Data.Models.Enums.BattleOutcome.Ongoing => "info",
            _ => "dark"
        };
    }
}
