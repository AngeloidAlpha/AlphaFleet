@model AlphaFleet.Data.Models.Station

@{
    ViewData["Title"] = Model.Name;
}

<div class="container mt-5">
    <h1 class="mb-4">@ViewData["Title"]</h1>

    <div class="card">
        <div class="row g-0">
            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="col-md-4 d-flex align-items-center justify-content-center p-3">
                    <img src="@Model.ImageUrl" alt="@Model.Name" class="img-fluid rounded" style="max-height: 300px;" />
                </div>
            }
            <div class="col-md-@(string.IsNullOrEmpty(Model.ImageUrl) ? "12" : "8")">
                <div class="card-body">
                    <dl class="row">
                        <dt class="col-sm-4">Name</dt>
                        <dd class="col-sm-8"><strong>@Model.Name</strong></dd>

                        <dt class="col-sm-4">Location</dt>
                        <dd class="col-sm-8">@Model.Location</dd>

                        <dt class="col-sm-4">Description</dt>
                        <dd class="col-sm-8">@Model.Description</dd>

                        <dt class="col-sm-4">Health</dt>
                        <dd class="col-sm-8">@Model.Health</dd>

                        <dt class="col-sm-4">Status</dt>
                        <dd class="col-sm-8">
                            @if (!Model.IsDestroyed)
                            {
                                <span class="badge bg-success">Active</span>
                            }
                            else
                            {
                                <span class="badge bg-danger">Destroyed</span>
                            }
                        </dd>
                    </dl>
                </div>
            </div>
        </div>
    </div>

    <div class="d-flex gap-2 mt-3">
        <a class="btn btn-secondary" asp-controller="Station" asp-action="Index">← Back to All Stations</a>
        <!-- TODO: Add Edit and Delete action links when implemented -->
    </div>
</div>

