@model IEnumerable<AlphaFleet.Data.Models.Station>

@{
    ViewData["Title"] = "Stations";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">@ViewData["Title"]</h1>
        <!-- TODO: Add Create action link when implemented -->
    </div>

    <form asp-controller="Station" asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by name or location..."
                   value="@ViewData["CurrentSearch"]" />
            <button type="submit" class="btn btn-primary">🔍 Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <a asp-controller="Station" asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
            }
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info" role="alert">
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <span>No stations found matching "<strong>@ViewData["CurrentSearch"]</strong>".</span>
            }
            else
            {
                <span>No stations found.</span>
            }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Location</th>
                        <th>Description</th>
                        <th>Health</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var station in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(station.ImageUrl))
                                {
                                    <img src="@station.ImageUrl" alt="@station.Name" style="width: 40px; height: 40px; border-radius: 5px;" />
                                }
                                else
                                {
                                    <span class="text-muted">—</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Station" asp-action="Details" asp-route-id="@station.Id">
                                    <strong>@station.Name</strong>
                                </a>
                            </td>
                            <td>@station.Location</td>
                            <td>@station.Description</td>
                            <td>@station.Health</td>
                            <td>
                                @if (!station.IsDestroyed)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Destroyed</span>
                                }
                            </td>
                            <td>
                                <!-- TODO: Add Edit and Delete action links when implemented -->
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
