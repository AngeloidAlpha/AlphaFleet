@model IEnumerable<AlphaFleet.Data.Models.Station>

@{
    ViewData["Title"] = "Stations";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0">@ViewData["Title"]</h1>
    </div>

    <form asp-controller="Station" asp-action="Index" method="get" class="mb-4">
        <div class="input-group">
            <input type="text" name="search" class="form-control" placeholder="Search by name or location..."
                   value="@ViewData["CurrentSearch"]" />
            <button type="submit" class="btn btn-primary">🔍 Search</button>
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <a asp-controller="Station" asp-action="Index" class="btn btn-outline-secondary">✕ Clear</a>
            }
        </div>
    </form>

    @if (Model == null || !Model.Any())
    {
        <div class="alert alert-info">
            @if (!string.IsNullOrEmpty(ViewData["CurrentSearch"]?.ToString()))
            {
                <span>No stations found matching "<strong>@ViewData["CurrentSearch"]</strong>".</span>
            }
            else { <span>No stations found.</span> }
        </div>
    }
    else
    {
        <div class="table-responsive">
            <table class="table table-striped table-hover">
                <thead class="table-dark">
                    <tr>
                        <th>Image</th>
                        <th>Name</th>
                        <th>Location</th>
                        <th>⚔️ Atk</th>
                        <th>🛡️ Def</th>
                        <th>❤️ HP</th>
                        <th>Status</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var station in Model)
                    {
                        <tr>
                            <td>
                                <img src="@(string.IsNullOrEmpty(station.ImageUrl) ? "/images/stations/default.png" : station.ImageUrl)"
                                     alt="@station.Name" style="width:40px;height:40px;border-radius:5px;object-fit:cover;" />
                            </td>
                            <td>
                                <a asp-controller="Station" asp-action="Details" asp-route-id="@station.Id">
                                    <strong>@station.Name</strong>
                                </a>
                            </td>
                            <td>@station.Location</td>
                            <td class="text-danger fw-bold">@station.Attack</td>
                            <td class="text-primary fw-bold">@station.Defense</td>
                            <td class="text-success fw-bold">@station.Health</td>
                            <td>
                                @if (!station.IsDestroyed)
                                {
                                    <span class="badge bg-success">Active</span>
                                }
                                else
                                {
                                    <span class="badge bg-danger">Destroyed</span>
                                }
                            </td>
                            <td>
                                <a asp-controller="Station" asp-action="Details" asp-route-id="@station.Id"
                                   class="btn btn-sm btn-outline-info">🔍 Details</a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    }
</div>
